# PlantaOS × Rock in Rio Lisboa 2026 — Backend Environment Variables

# Application
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_RELOAD=true

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:3000

# Optional: Gemini API key for AI chat
# If not set, local deterministic fallback is used
GEMINI_API_KEY=

# Optional: SCOR publishing token for KPI dashboards
# If not set, SCOR publishing is silently skipped
SCOR_TOKEN_KPI=

# Simulation settings
SIMULATION_TICK_INTERVAL_SECONDS=5
SIMULATION_INITIAL_SCENARIO=normal_day
